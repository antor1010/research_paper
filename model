        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import pandas as pd\n",
        "\n",
        "def calculate_detailed_power(x, y, base_stations):\n",
        "    Pt_dbm, Gt_dbi, Gr_dbi = 46, 15, 2\n",
        "    Pt = 10**(Pt_dbm / 10) / 1000\n",
        "    Gt, Gr = 10**(Gt_dbi / 10), 10**(Gr_dbi / 10)\n",
        "    fc, c = 915e6, 3e8\n",
        "    wavelength = c / fc\n",
        "    eta, blockage_loss_db, blockage_prob = 0.7, 20, 0.3\n",
